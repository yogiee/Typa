<!--
  Sparkle appcast for TextPad-NXG.
  Hosted at: https://raw.githubusercontent.com/yogiee/TextPad-NXG/main/appcast.xml

  Release flow:
    1. Bump CFBundleShortVersionString and CFBundleVersion in the .xcodeproj
    2. ./scripts/make-dmg.sh             → builds + packages + prints
                                           sparkle:edSignature and length
    3. gh release create vX.Y.Z build/TextPad-NXG-X.Y.Z.dmg --title …
    4. Add a new <item> block below (newest first) with the values printed by
       step 2 + the GitHub release download URL, then commit + push this file.
       Sparkle clients poll this URL and will pick up the new version.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>TextPad-NXG</title>
        <link>https://github.com/yogiee/TextPad-NXG</link>
        <description>Most recent changes with links to updates.</description>
        <language>en</language>

        <!--
          First release. No prior installs to update from, so no item block
          yet. The first <item> goes here once v0.2.0 is published.
        -->

    </channel>
</rss>
